{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": "client/src",
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["client/src/**/*.ts", "shared/**/*.ts"]
}
