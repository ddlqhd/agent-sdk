{
  "name": "@ddlqhd/agent-sdk-acp",
  "version": "0.1.0",
  "description": "ACP stdio bridge for @ddlqhd/agent-sdk (Zed / VS Code / JetBrains)",
  "type": "module",
  "bin": {
    "agent-sdk-acp": "./dist/entry.js"
  },
  "files": [
    "dist",
    "agent.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build",
    "start": "node dist/entry.js",
    "check": "node dist/entry.js --check"
